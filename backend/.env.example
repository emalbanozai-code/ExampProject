DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database
# DATABASE_URL=postgresql://user:password@localhost:5432/app
DJANGO_DB_CONN_MAX_AGE=600
DJANGO_DB_SSL_REQUIRE=false

# CORS / CSRF
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.up.railway.app
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://*.railway.app
DJANGO_CORS_ALLOW_ALL=false
DJANGO_CORS_ALLOW_CREDENTIALS=true

# Security
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SECURE_REFERRER_POLICY=same-origin

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Default superuser (optional; used by create_default_superuser)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_ROLE=admin

# Gunicorn (optional)
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
